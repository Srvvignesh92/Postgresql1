                        | grep -v -E \
                            '^AWS|^aws-|^StackSet-|^OrganizationAccount|^cdk-' \
                        | sort \
                        > candidate_iam_roles.txt

                        CANDIDATE=$(wc -l < candidate_iam_roles.txt | tr -d ' ')
