        //    /aws-reserved/*      – AWS-reserved system roles
        //
        //  NAME-based exclusions (roles that land on the root "/" path
        //  but are still AWS-owned or AWS-generated):
        //    AWS*                 – all AWS-prefixed managed/custom roles
        //                           (AWSServiceRoleFor*, AWSReservedSSO_*,
        //                            AWSBackup*, AWSGlue*, AWSConfig*, etc.)
        //    aws-*                – lowercase aws- prefix roles
        //                           (aws-controltower-*, aws-quicksight-*, etc.)
        //    StackSet-*           – CloudFormation StackSets execution roles
        //    OrganizationAccount* – AWS Organizations access role
        //    cdk-*                – AWS CDK bootstrap roles
        // ----------------------------------------------------------------
        stage('Retrieve Candidate IAM Roles') {
            steps {
                script {
                    echo "Fetching IAM roles and applying pre-filter..."

                    sh '''
                        set -e

                        # Fetch all roles: Path and RoleName columns
                        aws iam list-roles \
                            --query "Roles[*].[Path,RoleName]" \
                            --output text \
                        > all_iam_roles_raw.txt

                        TOTAL=$(wc -l < all_iam_roles_raw.txt | tr -d ' ')

                        # Step 1 – drop roles on AWS-owned paths
                        grep -v -E '^/aws-service-role/|^/aws-reserved/' \
                            all_iam_roles_raw.txt \
                        > path_filtered_roles.txt

