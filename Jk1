                            done < non_cfn_iam_roles.txt
                        else
                            echo "  (none)"
                        fi
                        echo ""
                        echo "================================================================"
                        echo ""
                    '''
                }
            }
        }
    }

    // ----------------------------------------------------------------
    // Post Actions
    // ----------------------------------------------------------------
    post {
