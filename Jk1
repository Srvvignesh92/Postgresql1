pipeline {
    agent any

    parameters {
        string(
            name: 'BA_VALUE',
            defaultValue: '',
            description: 'Business Application (BA) tag value to search for across AWS resources'
        )
    }

    environment {
        BA_LOWER = ''
    }

    options {
        timestamps()
        ansiColor('xterm')
    }

    stages {

        // ----------------------------------------------------------------
        // STAGE 1 – Validate & Normalise Input
        // ----------------------------------------------------------------
        stage('Validate and Normalize BA Input') {
            steps {
                script {
                    if (!params.BA_VALUE?.trim()) {
                        error("BA_VALUE parameter is empty. Please provide a valid Business Application tag value.")
                    }

                    // Convert to lowercase – BA tag is case-sensitive in AWS
                    env.BA_LOWER = params.BA_VALUE.trim().toLowerCase()

                    echo "============================================"
                    echo "  Input BA value   : ${params.BA_VALUE}"
                    echo "  Normalized value  : ${env.BA_LOWER}"
                    echo "============================================"
                }
            }
        }

        // ----------------------------------------------------------------
        // STAGE 2 – Retrieve Candidate IAM Roles (pre-filtered)
        //
        // Roles excluded up-front to avoid unnecessary API calls:
        //
        //  a) Service-Linked Roles  – path starts with /aws-service-role/
        //     These are AWS-managed, never carry customer BA tags, and there
        //     can be dozens of them (one per integrated AWS service).
        //
        //  b) AWS Default / managed roles – path starts with /aws-reserved/
        //     e.g. AWSServiceRoleFor*, OrganizationAccountAccessRole, etc.
        //
        //  c) Well-known AWS default role name prefixes that may sit on the
        //     root path ("/") but are still AWS-owned:
        //       - AWSReservedSSO_*   (SSO permission-set roles)
        //       - AWSServiceRoleFor* (service-linked roles on root path)
        //       - aws-controltower-* (Control Tower vended roles)
        //       - StackSet-*         (StackSets execution roles)
        //       - OrganizationAccountAccessRole
        //
        // Keeping only customer-created roles dramatically reduces the number
        // of list-role-tags API calls in Stage 3.
        // ----------------------------------------------------------------
        stage('Retrieve Candidate IAM Roles') {
            steps {
                script {
                    echo ">>> Fetching IAM roles – excluding service-linked and AWS default roles..."

                    sh '''
                        set -e

                        # ── Step 1: fetch ALL roles with both name and path ──────
                        # Output format per line:  <path>TAB<roleName>
                        aws iam list-roles \
                            --query "Roles[*].[Path,RoleName]" \
                            --output text \
                        > all_iam_roles_raw.txt

                        TOTAL=$(wc -l < all_iam_roles_raw.txt | tr -d ' ')
                        echo "Total IAM roles in account : ${TOTAL}"

                        # ── Step 2: exclude service-linked & AWS-reserved paths ──
                        # Paths /aws-service-role/* and /aws-reserved/* are AWS-owned
                        grep -v -E '^/aws-service-role/|^/aws-reserved/' \
                            all_iam_roles_raw.txt \
                        > path_filtered_roles.txt

                        PATH_FILTERED=$(wc -l < path_filtered_roles.txt | tr -d ' ')
                        echo "After path filter (removed SLRs & reserved): ${PATH_FILTERED}"

                        # ── Step 3: exclude well-known AWS default name prefixes ──
                        # Extract only the role name column (field 2) then drop
                        # names that match known AWS-managed naming conventions.
                        awk '{print $2}' path_filtered_roles.txt \
                        | grep -v -E \
                            '^AWSReservedSSO_|^AWSServiceRoleFor|^aws-controltower-|^StackSet-|^OrganizationAccountAccessRole' \
                        | sort \
                        > candidate_iam_roles.txt

                        CANDIDATE=$(wc -l < candidate_iam_roles.txt | tr -d ' ')
                        SKIPPED=$(( TOTAL - CANDIDATE ))
                        echo "Candidate roles to scan    : ${CANDIDATE}"
                        echo "Roles skipped (pre-filter) : ${SKIPPED}"

                        # clean up intermediate file
                        rm -f all_iam_roles_raw.txt path_filtered_roles.txt
                    '''
                }
            }
        }

        // ----------------------------------------------------------------
        // STAGE 3 – Filter Candidate Roles by BA Tag
        //
        // Iterates only the pre-filtered candidate list from Stage 2.
        // A lightweight inline guard provides a second line of defence:
        // any role whose name still matches a known AWS-managed pattern
        // is skipped with a log line before an API call is made.
        // ----------------------------------------------------------------
        stage('Filter IAM Roles by BA Tag') {
            steps {
                script {
                    echo ">>> Scanning candidate IAM roles for BA tag = '${env.BA_LOWER}' ..."

                    sh '''
                        set -e

                        BA_LOWER_SH="''' + env.BA_LOWER + '''"

                        > matched_iam_roles.txt   # clear/create output file

                        SCANNED=0
                        SKIPPED=0

                        while IFS= read -r ROLE_NAME; do
                            [ -z "$ROLE_NAME" ] && continue

                            # ── Inline safety-net skip (second line of defence) ──
                            # Catches any edge-case AWS-managed role that slipped
                            # through the path filter (e.g. on a non-standard path).
                            case "$ROLE_NAME" in
                                AWSReservedSSO_*       | \
                                AWSServiceRoleFor*     | \
                                aws-controltower-*     | \
                                StackSet-*             | \
                                OrganizationAccountAccessRole)
                                    echo "  [SKIP] AWS-managed role, no BA tag expected: $ROLE_NAME"
                                    SKIPPED=$(( SKIPPED + 1 ))
                                    continue
                                    ;;
                            esac

                            # ── Fetch BA tag and compare ─────────────────────────
                            TAGS=$(aws iam list-role-tags \
                                       --role-name "$ROLE_NAME" \
                                       --query "Tags[?Key=='BA'].Value" \
                                       --output text 2>/dev/null || true)

                            # Normalise fetched tag value to lowercase for comparison
                            TAGS_LOWER=$(echo "$TAGS" | tr '[:upper:]' '[:lower:]' | tr -d ' ')

                            SCANNED=$(( SCANNED + 1 ))

                            if [ "$TAGS_LOWER" = "$BA_LOWER_SH" ]; then
                                echo "  [MATCH] $ROLE_NAME"
                                echo "$ROLE_NAME" >> matched_iam_roles.txt
                            fi
                        done < candidate_iam_roles.txt

                        MATCH_COUNT=$(wc -l < matched_iam_roles.txt | tr -d ' ')
                        echo ""
                        echo "Roles scanned via API      : ${SCANNED}"
                        echo "Roles skipped (inline guard): ${SKIPPED}"
                        echo "Roles matching BA tag      : ${MATCH_COUNT}"
                    '''
                }
            }
        }

        // ----------------------------------------------------------------
        // STAGE 4 – Classify Matched Roles (CloudFormation vs Non-CFN)
        // ----------------------------------------------------------------
        stage('Classify IAM Roles by CloudFormation Ownership') {
            steps {
                script {
                    echo ">>> Classifying matched IAM roles by CloudFormation ownership..."

                    sh '''
                        set -e

                        > cfn_iam_roles.txt      # roles managed by CloudFormation
                        > non_cfn_iam_roles.txt  # roles NOT managed by CloudFormation

                        while IFS= read -r ROLE_NAME; do
                            [ -z "$ROLE_NAME" ] && continue

                            # Fetch all tag keys for this role
                            TAG_KEYS=$(aws iam list-role-tags \
                                           --role-name "$ROLE_NAME" \
                                           --query "Tags[*].Key" \
                                           --output text 2>/dev/null || true)

                            IS_CFN="false"

                            # CloudFormation stamps roles with these well-known tag keys
                            for KEY in $TAG_KEYS; do
                                KEY_LOWER=$(echo "$KEY" | tr '[:upper:]' '[:lower:]')
                                case "$KEY_LOWER" in
                                    aws:cloudformation:stack-name | \
                                    aws:cloudformation:stack-id   | \
                                    aws:cloudformation:logical-id | \
                                    cloudformation:stack-name     | \
                                    cft:stack-name                | \
                                    cft-stack-name                | \
                                    cft_stack_name)
                                        IS_CFN="true"
                                        break
                                        ;;
                                esac
                            done

                            if [ "$IS_CFN" = "true" ]; then
                                echo "$ROLE_NAME" >> cfn_iam_roles.txt
                            else
                                echo "$ROLE_NAME" >> non_cfn_iam_roles.txt
                            fi
                        done < matched_iam_roles.txt

                        echo "Roles managed by CloudFormation   : $(wc -l < cfn_iam_roles.txt    | tr -d ' ')"
                        echo "Roles NOT managed by CloudFormation: $(wc -l < non_cfn_iam_roles.txt | tr -d ' ')"
                    '''
                }
            }
        }

        // ----------------------------------------------------------------
        // STAGE 5 – Retrieve & Filter Security Groups by BA Tag
        // ----------------------------------------------------------------
        stage('Retrieve Security Groups by BA Tag') {
            steps {
                script {
                    echo ">>> Fetching security groups with BA tag = '${env.BA_LOWER}' ..."

                    sh '''
                        set -e

                        BA_LOWER_SH="''' + env.BA_LOWER + '''"

                        # Use AWS tag filter directly – more efficient than looping
                        aws ec2 describe-security-groups \
                            --filters \
                                "Name=tag-key,Values=BA" \
                                "Name=tag-value,Values=${BA_LOWER_SH}" \
                            --query "SecurityGroups[*].[GroupId,GroupName,Description]" \
                            --output text \
                        > matched_security_groups.txt

                        SG_COUNT=$(wc -l < matched_security_groups.txt | tr -d ' ')
                        echo "Security groups matching BA='${BA_LOWER_SH}': ${SG_COUNT}"
                    '''
                }
            }
        }

        // ----------------------------------------------------------------
        // STAGE 6 – Print Summary Report
        // ----------------------------------------------------------------
        stage('Print Summary Report') {
            steps {
                script {
                    sh '''
                        echo ""
                        echo "########################################################"
                        echo "#           AWS Resource Discovery Summary             #"
                        echo "########################################################"
                        echo ""
                        echo "  Business Application (BA) tag value : ''' + env.BA_LOWER + '''"
                        echo ""

                        # ── Matched IAM Roles ───────────────────────────────────
                        echo "------------------------------------------------------------"
                        echo "  IAM Roles matching BA tag ($(wc -l < matched_iam_roles.txt | tr -d ' ') found)"
                        echo "------------------------------------------------------------"
                        if [ -s matched_iam_roles.txt ]; then
                            while IFS= read -r ROLE; do
                                echo "    - $ROLE"
                            done < matched_iam_roles.txt
                        else
                            echo "    (none)"
                        fi
                        echo ""

                        # ── CFN-Managed Roles ────────────────────────────────────
                        echo "------------------------------------------------------------"
                        echo "  IAM Roles managed by CloudFormation ($(wc -l < cfn_iam_roles.txt | tr -d ' ') found)"
                        echo "------------------------------------------------------------"
                        if [ -s cfn_iam_roles.txt ]; then
                            while IFS= read -r ROLE; do
                                echo "    - $ROLE"
                            done < cfn_iam_roles.txt
                        else
                            echo "    (none)"
                        fi
                        echo ""

                        # ── Non-CFN Roles ────────────────────────────────────────
                        echo "------------------------------------------------------------"
